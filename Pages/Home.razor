@page "/"
@inject IJSRuntime JSRuntime

<PageTitle>3D Dungeon Crawler</PageTitle>

<div class="game-container">
    <canvas id="renderCanvas" style="width: 100%; height: 100vh; touch-action: none;"></canvas>

    @if (CurrentState == GameState.MainMenu)
    {
        <div class="overlay main-menu">
            <h1 class="title">DUNGEON CRAWLER</h1>
            @if (HasSave)
            {
                <button class="btn-start btn-continue" @onclick="ContinueGame">CONTINUE</button>
                <button class="btn-menu btn-newgame" @onclick="NewGame">NEW GAME</button>
            }
            else
            {
                <button class="btn-start" @onclick="NewGame">ENTER DUNGEON</button>
            }
            <div class="subtitle">Descend into the darkness...</div>
        </div>
    }

    @if (CurrentState == GameState.ContinueMenu)
    {
        <div class="overlay selection-menu">
            <h2>GAME CONTINUED</h2>
            <div class="status-summary">LVL @(SaveData?.TryGetProperty("level", out var l) == true ? l.ToString() : "1") WARRIOR (Floor @(SaveData?.TryGetProperty("currentLevel", out var f) == true ? f.ToString() : "1"))</div>
            <button class="btn-start" @onclick="StartDungeon">ENTER DUNGEON</button>
            <button class="btn-menu" @onclick="OpenShop">ENTER SHOP</button>
            <button class="btn-menu btn-back" @onclick="ExitToMain">BACK</button>
        </div>
    }

    @if (CurrentState == GameState.Shop)
    {
        <div class="overlay shop-menu">
            <h2>CHARACTER & TREASURE</h2>
            
            <div class="shop-container">
                <!-- Left: Paper Doll -->
                <div class="paper-doll-section">
                    <div class="portrait-wrapper">
                        <canvas id="portraitCanvas"></canvas>
                    </div>
                    <div class="stats-panel">
                        <div>BASE ATK: @(15 + (SaveData?.TryGetProperty("level", out var lv) == true ? lv.GetInt32() : 1) * 2 + (SaveData?.TryGetProperty("bonusDmg", out var bd) == true ? bd.GetInt32() : 0))</div>
                        <div>GOLD: 💰 @(SaveData?.TryGetProperty("gold", out var g) == true ? g.ToString() : "0")</div>
                    </div>
                    <div class="equipment-slots">
                        @foreach(var slot in new[] { "head", "chest", "hands", "legs", "feet", "rightHand", "leftHand" })
                        {
                            var s = slot;
                            var item = GetEquippedItem(s);
                            <div class="eq-slot @s" title="@s">
                                @if (item != null)
                                {
                                    <div class="item-icon equipped" @onclick="() => UnequipItem(s)">@item.Value.GetProperty("name").GetString().Substring(0,1)</div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Right: Shop & Inventory Tabs -->
                <div class="tabs-section">
                    <div class="tabs">
                        <button class="tab-btn @(activeTab == "shop" ? "active" : "")" @onclick='() => activeTab = "shop"'>SHOP</button>
                        <button class="tab-btn @(activeTab == "inv" ? "active" : "")" @onclick='() => activeTab = "inv"'>INVENTORY</button>
                    </div>

                    @if (activeTab == "shop")
                    {
                        <div class="tab-content">
                            <div class="shop-item">
                                <div class="item-info">HEALING POTION</div>
                                <button class="btn-buy" @onclick="BuyHeal" disabled="@((SaveData?.TryGetProperty("gold", out var g2) == true ? g2.GetInt32() : 0) < 25)">25G</button>
                            </div>
                            <div class="shop-item">
                                <div class="item-info">IRON HELMET (+2 DEF)</div>
                                <button class="btn-buy" @onclick='() => BuyItem("Iron Helmet", "head", "data/shield.json", 100)' disabled="@((SaveData?.TryGetProperty("gold", out var g3) == true ? g3.GetInt32() : 0) < 100)">100G</button>
                            </div>
                            <div class="shop-item">
                                <div class="item-info">STEEL SHIELD</div>
                                <button class="btn-buy" @onclick='() => BuyItem("Steel Shield", "leftHand", "data/shield.json", 200)' disabled="@((SaveData?.TryGetProperty("gold", out var g4) == true ? g4.GetInt32() : 0) < 200)">200G</button>
                            </div>
                            <div class="shop-item">
                                <div class="item-info">SHARPEN BLADE (+5 DMG)</div>
                                <button class="btn-buy" @onclick="BuyStrength" disabled="@((SaveData?.TryGetProperty("gold", out var g5) == true ? g5.GetInt32() : 0) < 150)">150G</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="tab-content inventory-grid">
                            @for (int i = 0; i < 16; i++)
                            {
                                var index = i;
                                var invItem = GetInventoryItem(index);
                                <div class="grid-slot">
                                    @if (invItem != null)
                                    {
                                        <div class="item-icon" @onclick="() => EquipItem(index)">@invItem.Value.GetProperty("name").GetString().Substring(0,1)</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <button class="btn-menu" @onclick="BackToSelection">BACK</button>
        </div>
    }

    @if (CurrentState == GameState.ESCMenu)
    {
        <div class="overlay esc-menu">
            <h2>PAUSED</h2>
            <button class="btn-menu" @onclick="ResumeGame">RESUME</button>
            <button class="btn-menu" @onclick="ExitDungeon">EXIT DUNGEON</button>
        </div>
    }
</div>

@code {
    private enum GameState { MainMenu, ContinueMenu, Playing, ESCMenu, Shop }
    private GameState CurrentState = GameState.MainMenu;
    private bool HasSave = false;
    private System.Text.Json.JsonElement? SaveData = null;
    private string activeTab = "shop";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "dungeonSave");
            HasSave = !string.IsNullOrEmpty(saveJson);
            StateHasChanged();
        }
    }

    private async Task NewGame()
    {
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "dungeonSave");
        CurrentState = GameState.Playing;
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.init", "renderCanvas", DotNetObjectReference.Create(this));
    }

    private async Task ContinueGame()
    {
        var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "dungeonSave");
        if (!string.IsNullOrEmpty(saveJson))
        {
            SaveData = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(saveJson);
            CurrentState = GameState.ContinueMenu;
        }
    }

    private async Task StartDungeon()
    {
        CurrentState = GameState.Playing;
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.init", "renderCanvas", DotNetObjectReference.Create(this), (object)SaveData);
    }

    private void OpenShop() 
    {
        CurrentState = GameState.Shop;
        Task.Run(async () => {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.initPortrait", "portraitCanvas", (object)SaveData);
        });
    }

    private System.Text.Json.JsonElement? GetInventoryItem(int index)
    {
        try {
            if (SaveData?.TryGetProperty("inventory", out var inv) == true)
            {
                if (inv.GetArrayLength() > index) return inv[index];
            }
        } catch {}
        return null;
    }

    private System.Text.Json.JsonElement? GetEquippedItem(string slot)
    {
        try {
            if (SaveData?.TryGetProperty("equipment", out var eq) == true)
            {
                if (eq.TryGetProperty(slot, out var item)) return item;
            }
        } catch {}
        return null;
    }

    private void BackToSelection() => CurrentState = GameState.ContinueMenu;
    private void ExitToMain() => CurrentState = GameState.MainMenu;

    private async Task BuyHeal()
    {
        if (SaveData?.GetProperty("gold").GetInt32() >= 25)
        {
            await UpdateAndSave("gold", SaveData.Value.GetProperty("gold").GetInt32() - 25);
        }
    }

    private async Task BuyStrength()
    {
        if (SaveData?.GetProperty("gold").GetInt32() >= 150)
        {
            var bonusDmg = 0;
            try { bonusDmg = SaveData.Value.GetProperty("bonusDmg").GetInt32(); } catch {}
            await UpdateAndSave("gold", SaveData.Value.GetProperty("gold").GetInt32() - 150, "bonusDmg", bonusDmg + 5);
        }
    }

    private async Task BuyItem(string name, string slot, string model, int price)
    {
        if (SaveData?.TryGetProperty("gold", out var g) == true && g.GetInt32() >= price)
        {
            List<object> inv = new List<object>();
            if (SaveData?.TryGetProperty("inventory", out var existingInv) == true)
            {
                inv = System.Text.Json.JsonSerializer.Deserialize<List<object>>(existingInv.GetRawText());
            }
            inv.Add(new { name, slot, modelPath = model, id = Guid.NewGuid().ToString() });
            await UpdateAndSave("gold", g.GetInt32() - price, "inventory", inv);
        }
    }

    private async Task EquipItem(int index)
    {
        var item = GetInventoryItem(index);
        if (item == null) return;
        var slot = item.Value.GetProperty("slot").GetString();
        
        var eq = new Dictionary<string, object>();
        if (SaveData?.TryGetProperty("equipment", out var existingEq) == true)
        {
            eq = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(existingEq.GetRawText());
        }

        var inv = new List<object>();
        if (SaveData?.TryGetProperty("inventory", out var existingInv) == true)
        {
            inv = System.Text.Json.JsonSerializer.Deserialize<List<object>>(existingInv.GetRawText());
        }
        
        // Remove from inventory
        inv.RemoveAt(index);
        // If something was in slot, add back to inventory
        if (eq.ContainsKey(slot) && eq[slot] != null) inv.Add(eq[slot]);
        
        eq[slot] = item;
        await UpdateAndSave("equipment", eq, "inventory", inv);
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.initPortrait", "portraitCanvas", (object)SaveData);
    }

    private async Task UnequipItem(string slot)
    {
        var item = GetEquippedItem(slot);
        if (item == null) return;
        var eq = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(SaveData.Value.GetProperty("equipment").GetRawText());
        var inv = System.Text.Json.JsonSerializer.Deserialize<List<object>>(SaveData.Value.GetProperty("inventory").GetRawText());
        
        inv.Add(item);
        eq[slot] = null;
        await UpdateAndSave("equipment", eq, "inventory", inv);
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.initPortrait", "portraitCanvas", (object)SaveData);
    }

    private async Task UpdateAndSave(params object[] kvs)
    {
        var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "dungeonSave");
        var dict = System.Text.Json.JsonSerializer.Deserialize<System.Collections.Generic.Dictionary<string, object>>(saveJson);
        for(int i=0; i<kvs.Length; i+=2) dict[kvs[i].ToString()] = kvs[i+1];
        var newSave = System.Text.Json.JsonSerializer.Serialize(dict);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "dungeonSave", newSave);
        SaveData = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(newSave);
        StateHasChanged();
    }

    private void ResumeGame()
    {
        CurrentState = GameState.Playing;
    }

    private void ExitDungeon()
    {
        CurrentState = GameState.MainMenu;
        // Re-check for save upon exit
        CheckForSave();
    }

    private async void CheckForSave()
    {
        var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "dungeonSave");
        HasSave = !string.IsNullOrEmpty(saveJson);
        StateHasChanged();
    }

    [JSInvokable]
    public void ToggleESCMenu()
    {
        if (CurrentState == GameState.Playing) CurrentState = GameState.ESCMenu;
        else if (CurrentState == GameState.ESCMenu) CurrentState = GameState.Playing;
        StateHasChanged();
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Almendra+SC&family=MedievalSharp&display=swap');

    .game-container {
        width: 100%;
        height: 100vh;
        overflow: hidden;
        margin: 0;
        padding: 0;
        background: #000;
        position: relative;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        background: rgba(0, 0, 0, 0.7);
        z-index: 100;
        color: #fff;
        text-align: center;
    }

    .main-menu {
        background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url('images/start_bg.png');
        background-size: cover;
        background-position: center;
    }

    .title {
        font-family: 'Almendra SC', serif;
        font-size: 5rem;
        color: #d4af37;
        text-shadow: 0 0 20px rgba(212, 175, 55, 0.6), 4px 4px 5px #000;
        margin-bottom: 2rem;
        letter-spacing: 0.5rem;
    }

    .subtitle {
        font-family: 'MedievalSharp', cursive;
        font-size: 1.2rem;
        color: #aaa;
        margin-top: 2rem;
        letter-spacing: 0.2rem;
    }

    .btn-start {
        font-family: 'MedievalSharp', cursive;
        padding: 1.5rem 4rem;
        font-size: 2rem;
        background: #8b0000;
        color: white;
        border: 3px solid #d4af37;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 0 15px rgba(139, 0, 0, 0.5);
    }

    .btn-start:hover {
        background: #a52a2a;
        transform: scale(1.05);
        box-shadow: 0 0 25px rgba(212, 175, 55, 0.8);
    }

    .btn-continue {
        margin-bottom: 1rem;
    }

    .btn-newgame {
        width: 200px !important;
        background: #333 !important;
        border-color: #666 !important;
    }

    .status-summary {
        font-family: 'MedievalSharp', cursive;
        color: #d4af37;
        font-size: 1.5rem;
        margin-bottom: 2rem;
    }

    .btn-back {
        background: #444 !important;
        width: 150px !important;
        margin-top: 2rem !important;
    }

    .gold-display {
        font-family: 'MedievalSharp', cursive;
        font-size: 2rem;
        color: #FFD700;
        margin-bottom: 2rem;
    }

    .shop-container {
        display: flex;
        width: 90%;
        max-width: 1000px;
        height: 600px;
        background: rgba(20,20,25,0.9);
        border: 3px solid #d4af37;
        padding: 20px;
        margin-bottom: 20px;
        gap: 20px;
    }

    .paper-doll-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
    }

    .portrait-wrapper {
        width: 100%;
        height: 400px;
        border: 1px solid #444;
        background: #000;
    }

    #portraitCanvas { width: 100%; height: 100%; }

    .equipment-slots {
        position: absolute;
        width: 100%;
        height: 400px;
        pointer-events: none;
    }

    .eq-slot {
        position: absolute;
        width: 50px;
        height: 50px;
        background: rgba(0,0,0,0.5);
        border: 1px solid #d4af37;
        pointer-events: all;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 0.8rem;
    }

    .eq-slot.head { top: 10px; left: 50%; transform: translateX(-50%); }
    .eq-slot.chest { top: 160px; left: 50%; transform: translateX(-50%); }
    .eq-slot.hands { top: 160px; left: 20%; }
    .eq-slot.rightHand { top: 220px; left: 10%; }
    .eq-slot.leftHand { top: 220px; right: 10%; }
    .eq-slot.legs { top: 280px; left: 50%; transform: translateX(-50%); }
    .eq-slot.feet { top: 360px; left: 50%; transform: translateX(-50%); }

    .item-icon {
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #444;
        cursor: pointer;
        font-family: 'Almendra SC';
    }

    .item-icon.equipped { background: #d4af37; color: #000; }

    .tabs-section { flex: 1.2; display: flex; flex-direction: column; }
    .tabs { display: flex; gap: 10px; margin-bottom: 10px; }
    .tab-btn { flex: 1; padding: 10px; background: #222; color: #aaa; border: 1px solid #444; cursor: pointer; }
    .tab-btn.active { background: #d4af37; color: #000; border-color: #fff; }

    .tab-content { flex: 1; overflow-y: auto; padding: 10px; background: rgba(0,0,0,0.3); }

    .inventory-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
        grid-auto-rows: 70px;
    }

    .grid-slot { border: 1px dashed #555; background: rgba(0,0,0,0.2); }

    .shop-menu h2 {
        font-family: 'Almendra SC', serif;
        font-size: 3rem;
        color: #d4af37;
        margin-bottom: 1rem;
    }

    .shop-item {
        background: rgba(40,40,40,0.8);
        border: 2px solid #555;
        padding: 1.5rem;
        margin: 0.5rem;
        width: 500px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-radius: 8px;
    }

    .item-info {
        font-family: 'MedievalSharp', cursive;
        font-size: 1.1rem;
    }

    .btn-buy {
        font-family: 'MedievalSharp', cursive;
        padding: 0.5rem 1.5rem;
        background: #006400;
        color: white;
        border: 2px solid #004d00;
        cursor: pointer;
        border-radius: 4px;
        transition: transform 0.1s;
    }

    .btn-buy:hover:not(:disabled) {
        background: #008000;
        transform: scale(1.05);
    }

    .btn-buy:disabled {
        background: #333;
        color: #777;
        border-color: #222;
        cursor: not-allowed;
    }

    .esc-menu h2 {
        font-family: 'Almendra SC', serif;
        font-size: 3rem;
        color: #d4af37;
        margin-bottom: 2rem;
    }

    .btn-menu {
        font-family: 'MedievalSharp', cursive;
        padding: 1rem 3rem;
        font-size: 1.5rem;
        background: #222;
        color: #eee;
        border: 2px solid #555;
        margin: 0.5rem;
        width: 300px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn-menu:hover {
        background: #444;
        border-color: #d4af37;
    }

    body, html { margin: 0; padding: 0; overflow: hidden; }
    .top-row, .sidebar { display: none !important; }
    .content { padding: 0 !important; }
</style>
