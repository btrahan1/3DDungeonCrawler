@page "/"
@inject IJSRuntime JSRuntime

<PageTitle>3D Dungeon Crawler</PageTitle>

<div class="game-container">
    <canvas id="renderCanvas" style="width: 100%; height: 100vh; touch-action: none;"></canvas>

    @if (CurrentState == GameState.MainMenu)
    {
        <div class="overlay main-menu">
            <h1 class="title">DUNGEON CRAWLER</h1>
            <button class="btn-start" @onclick="OpenCharacterSelect">START JOURNEY</button>
            <div class="subtitle">Descend into the darkness...</div>
        </div>
    }

    @if (CurrentState == GameState.CharacterSelect)
    {
        <div class="overlay char-select-menu">
            <h2 class="title-small">SELECT CHARACTER</h2>
            <div class="slots-container">
                @for (int i = 0; i < 3; i++)
                {
                    var slotIndex = i;
                    var meta = SlotMeta.ContainsKey(slotIndex) ? SlotMeta[slotIndex] : null;
                    <div class="char-slot @(meta == null ? "empty" : "active")">
                        @if (meta != null)
                        {
                            <div class="slot-info">
                                <div class="slot-name">@meta.Name</div>
                                <div class="slot-stats">LVL @meta.Level @meta.Class</div>
                                <div class="slot-floor">FLOOR @meta.Floor</div>
                            </div>
                            <div class="slot-actions">
                                <button class="btn-slot btn-resume" @onclick="() => LoadCharacter(slotIndex)">RESUME</button>
                                <button class="btn-slot btn-delete" @onclick="() => ConfirmDelete(slotIndex)">DELETE</button>
                            </div>
                        }
                        else
                        {
                            <div class="slot-empty-text">EMPTY SLOT</div>
                            @if (creatingSlot == slotIndex)
                            {
                                <div class="name-entry">
                                    <input @bind="newName" placeholder="NAME..." maxlength="12" />
                                    <button class="btn-slot btn-create" @onclick="() => CreateCharacter(slotIndex)">CREATE</button>
                                </div>
                            }
                            else
                            {
                                <button class="btn-slot btn-new" @onclick="() => creatingSlot = slotIndex">NEW HERO</button>
                            }
                        }
                    </div>
                }
            </div>
            <button class="btn-menu btn-back" @onclick="ExitToMain">BACK</button>
        </div>
    }

    @if (CurrentState == GameState.ContinueMenu)
    {
        <div class="overlay selection-menu">
            <h2>@(SaveData?.TryGetProperty("name", out var n) == true ? n.GetString() : "HERO") CONTINUED</h2>
            <div class="status-summary">LVL @(SaveData?.TryGetProperty("level", out var l) == true ? l.ToString() : "1") @(SaveData?.TryGetProperty("class", out var c) == true ? c.GetString() : "WARRIOR") (Floor @(SaveData?.TryGetProperty("currentLevel", out var f) == true ? f.ToString() : "1"))</div>
            <button class="btn-start" @onclick="StartDungeon">ENTER DUNGEON</button>
            <button class="btn-menu" @onclick="OpenShop">ENTER SHOP</button>
            <button class="btn-menu btn-back" @onclick="OpenCharacterSelect">BACK</button>
        </div>
    }

    @if (CurrentState == GameState.Shop || CurrentState == GameState.ESCMenu)
    {
        <div class="overlay shop-menu @(CurrentState == GameState.ESCMenu ? "esc-inventory" : "")">
            <h2>@(CurrentState == GameState.Shop ? "CHARACTER & TREASURE" : "CHARACTER SHEET")</h2>
            
            <div class="shop-container">
                <!-- Left: Paper Doll -->
                <div class="paper-doll-section">
                    <div class="portrait-wrapper">
                        <canvas id="portraitCanvas"></canvas>
                    </div>
                    <div class="stats-panel">
                        <div>TOTAL ATK: ⚔️ @(15 + (SaveData?.TryGetProperty("level", out var lv) == true ? lv.GetInt32() : 1) * 2 + (SaveData?.TryGetProperty("bonusDmg", out var bd) == true ? bd.GetInt32() : 0) + GetWeaponPower() * 5)</div>
                        <div>DEFENSE: 🛡️ @GetTotalArmor()</div>
                        <div>GOLD: 💰 @(SaveData?.TryGetProperty("gold", out var g) == true ? g.ToString() : "0")</div>
                    </div>
                    <div class="equipment-slots">
                        @foreach(var slot in new[] { "head", "chest", "hands", "legs", "feet", "rightHand", "leftHand" })
                        {
                            var s = slot;
                            var item = GetEquippedItem(s);
                            bool hasItem = item != null && item.Value.ValueKind != System.Text.Json.JsonValueKind.Null;
                            <div class="eq-slot @s" title="@(hasItem ? $"{item.Value.GetProperty("name").GetString()} (Power: {(item.Value.TryGetProperty("power", out var p) ? p.GetInt32() : 0)})" : s)">
                                @if (hasItem)
                                {
                                    <div class='item-icon equipped tier-@(item.Value.TryGetProperty("tier", out var t) ? t.GetString().ToLower() : "iron")' @onclick="() => UnequipItem(s)">
                                        @((MarkupString)GetSvgIcon(s))
                                    </div>
                                }
                                else
                                {
                                    <div class="slot-placeholder">@((MarkupString)GetSvgIcon(s))</div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Right: Shop & Inventory Tabs -->
                <div class="tabs-section">
                    <div class="tabs">
                        @if (CurrentState == GameState.Shop) {
                            <button class="tab-btn @(activeTab == "shop" ? "active" : "")" @onclick='() => activeTab = "shop"'>SHOP</button>
                        }
                        <button class="tab-btn @(activeTab == "inv" || CurrentState == GameState.ESCMenu ? "active" : "")" @onclick='() => activeTab = "inv"'>INVENTORY</button>
                    </div>

                    @if (activeTab == "shop" && CurrentState == GameState.Shop)
                    {
                        <div class="tab-content">
                            <div class="shop-item">
                                <div class="item-info">HEALING POTION</div>
                                <button class="btn-buy" @onclick="BuyHeal" disabled="@((SaveData?.TryGetProperty("gold", out var g2) == true ? g2.GetInt32() : 0) < 25)">25G</button>
                            </div>
                            <div class="shop-item">
                                <div class="item-info">IRON HELMET (+2 DEF)</div>
                                <button class="btn-buy" @onclick='() => BuyItem("Iron Helmet", "head", "data/shield.json", 100)' disabled="@((SaveData?.TryGetProperty("gold", out var g3) == true ? g3.GetInt32() : 0) < 100)">100G</button>
                            </div>
                            <div class="shop-item">
                                <div class="item-info">STEEL SHIELD</div>
                                <button class="btn-buy" @onclick='() => BuyItem("Steel Shield", "leftHand", "data/shield.json", 200)' disabled="@((SaveData?.TryGetProperty("gold", out var g4) == true ? g4.GetInt32() : 0) < 200)">200G</button>
                            </div>
                            <div class="shop-item">
                                <div class="item-info">SHARPEN BLADE (+5 DMG)</div>
                                <button class="btn-buy" @onclick="BuyStrength" disabled="@((SaveData?.TryGetProperty("gold", out var g5) == true ? g5.GetInt32() : 0) < 150)">150G</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="tab-content inventory-grid">
                            @for (int i = 0; i < 16; i++)
                            {
                                var index = i;
                                var invItem = GetInventoryItem(index);
                                <div class="grid-slot">
                                    @if (invItem != null)
                                    {
                                        var slotNm = invItem.Value.GetProperty("slot").GetString();
                                        <div class='item-icon tier-@(invItem.Value.TryGetProperty("tier", out var t) ? t.GetString().ToLower() : "iron")' 
                                             title='@invItem.Value.GetProperty("name").GetString() (Power: {(invItem.Value.TryGetProperty("power", out var p) ? p.GetInt32() : 0)})'
                                             @onclick="() => EquipItem(index)">
                                            @((MarkupString)GetSvgIcon(slotNm))
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            @if (CurrentState == GameState.Shop) {
                <button class="btn-menu" @onclick="BackToSelection">BACK</button>
            } else {
                <div class="esc-buttons">
                    <button class="btn-menu" @onclick="ResumeGame">RESUME</button>
                    <button class="btn-menu" @onclick="ExitDungeon">EXIT DUNGEON</button>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(LootMessage))
    {
        <div class="loot-notification">
            <div class="loot-title">LOOT FOUND!</div>
            <div class="loot-item">@LootMessage</div>
        </div>
    }
 </div>

@code {
    private enum GameState { MainMenu, CharacterSelect, ContinueMenu, Playing, ESCMenu, Shop }
    private GameState CurrentState = GameState.MainMenu;
    private bool HasSave = false;
    private System.Text.Json.JsonElement? SaveData = null;
    private int activeSlot = 0;
    private int? creatingSlot = null;
    private string newName = "";
    private string activeTab = "shop";
    private string LootMessage = "";
    
    private class SlotMetadata {
        public string Name { get; set; } = "Adventurer";
        public int Level { get; set; } = 1;
        public int Floor { get; set; } = 1;
        public string Class { get; set; } = "WARRIOR";
    }
    private Dictionary<int, SlotMetadata> SlotMeta = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
    {
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "dungeonSave");
        CurrentState = GameState.Playing;
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.init", "renderCanvas", DotNetObjectReference.Create(this));
    }

    private async Task ContinueGame()
    {
        var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "dungeonSave");
        if (!string.IsNullOrEmpty(saveJson))
        {
            SaveData = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(saveJson);
            CurrentState = GameState.ContinueMenu;
        }
    }

    private async Task StartDungeon()
    {
        CurrentState = GameState.Playing;
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.init", "renderCanvas", DotNetObjectReference.Create(this), (object)SaveData);
    }

    private async Task OpenShop() 
    {
        CurrentState = GameState.Shop;
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.initPortrait", "portraitCanvas", (object)SaveData);
    }

    [JSInvokable]
    public void OnPause()
    {
        CurrentState = GameState.ESCMenu;
        activeTab = "inv";
        StateHasChanged();
        Task.Run(async () => {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.initPortrait", "portraitCanvas", (object)SaveData);
        });
    }

    [JSInvokable]
    public async Task ClaimBossLoot(int dungeonLevel)
    {
        string[] slots = { "head", "chest", "hands", "legs", "feet", "rightHand", "leftHand" };
        string slot = slots[new Random().Next(slots.Length)];
        
        string tier = dungeonLevel < 3 ? "Iron" : (dungeonLevel < 7 ? "Steel" : "Mythril");
        int power = dungeonLevel;
        
        string name = $"{tier} {slot[0].ToString().ToUpper() + slot.Substring(1)}";
        if (slot.Contains("Hand")) name = $"{tier} {(slot == "rightHand" ? "Sword" : "Shield")}";

        string model = slot == "leftHand" ? "data/shield.json" : (slot == "rightHand" ? "data/sword.json" : "data/shield.json");

        var newItem = new { name, slot, modelPath = model, id = Guid.NewGuid().ToString(), power, tier };

        var inv = new List<object>();
        if (SaveData?.TryGetProperty("inventory", out var existingInv) == true)
            inv = System.Text.Json.JsonSerializer.Deserialize<List<object>>(existingInv.GetRawText()) ?? new List<object>();
            
        inv.Add(newItem);
        await UpdateAndSave("inventory", inv);
        
        LootMessage = name;
        StateHasChanged(); // Force update so banner shows item is added
        await Task.Delay(4000);
        LootMessage = "";
        StateHasChanged();
    }

    private string GetSvgIcon(string slot)
    {
        string color = "currentColor";
        string head = "<path d='M12 2L4 5v6c0 5.5 3.5 10.3 8 12 4.5-1.7 8-6.5 8-12V5l-8-3zm0 2l6 2.2v4.8c0 4.1-2.6 7.8-6 9.2-3.4-1.4-6-5.1-6-9.2V6.2L12 4zm-1 3v2h2V7h-2z'/>";
        string chest = "<path d='M12 2L4 5v2c0 2.3 1.1 4.5 3 6v7h10v-7c1.9-1.5 3-3.7 3-6V5l-8-3zM8 7h8v3H8V7zm2 5h4v5h-4v-5z'/>";
        string hands = "<path d='M6 10c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h4c1.1 0 2-.9 2-2v-4h4v4c0 1.1.9 2 2 2h4c1.1 0 2-.9 2-2v-8c0-1.1-.9-2-2-2h-14zm2 2h2v6H8v-6zm12 0h2v6h-2v-6z'/>";
        string legs = "<path d='M6 2v10c0 4 3 7 3 10h6c0-3 3-6 3-10V2H6zm2 2h8v6H8V4zm2 8h4v6h-4v-6z'/>";
        string feet = "<path d='M6 18l-2 4h4l1-2h6l1 2h4l-2-4V10H6v8zm2-6h8v4H8v-4z'/>";
        string rightHand = "<path d='M19.3 4.7L18 3.4 11 10.4 7.5 7 6.1 8.4 9.6 11.9 3.4 18.1 6.1 20.8 12.3 14.6 15.8 18.1 17.2 16.7 13.7 13.2z'/>";
        string leftHand = "<path d='M12 2L4 5v6c0 5.5 3.5 10.3 8 12 4.5-1.7 8-6.5 8-12V5l-8-3zm0 2l6 2.2v4.8c0 4.1-2.6 7.8-6 9.2-3.4-1.4-6-5.1-6-9.2V6.2L12 4zm-2 5h4v2h-4V9z'/>";

        string path = slot switch {
            "head" => head, "chest" => chest, "hands" => hands, "legs" => legs, "feet" => feet, "rightHand" => rightHand, "leftHand" => leftHand, _ => ""
        };
        return $"<svg viewBox='0 0 24 24' fill='{color}' width='100%' height='100%'>{path}</svg>";
    }

    private System.Text.Json.JsonElement? GetInventoryItem(int index)
    {
        try {
            if (SaveData?.TryGetProperty("inventory", out var inv) == true)
            {
                if (inv.GetArrayLength() > index && inv[index].ValueKind != System.Text.Json.JsonValueKind.Null) return inv[index];
            }
        } catch {}
        return null;
    }

    private System.Text.Json.JsonElement? GetEquippedItem(string slot)
    {
        try {
            if (SaveData?.TryGetProperty("equipment", out var eq) == true)
            {
                if (eq.TryGetProperty(slot, out var item) && item.ValueKind != System.Text.Json.JsonValueKind.Null) return item;
            }
        } catch {}
        return null;
    }

    private int GetWeaponPower()
    {
        var item = GetEquippedItem("rightHand");
        if (item != null && item.Value.TryGetProperty("power", out var p)) return p.GetInt32();
        return 0;
    }

    private int GetTotalArmor()
    {
        int total = 0;
        foreach(var slot in new[] { "head", "chest", "hands", "legs", "feet", "leftHand" })
        {
            var item = GetEquippedItem(slot);
            if (item != null && item.Value.TryGetProperty("power", out var p)) total += p.GetInt32();
        }
        return total;
    }

    private void BackToSelection() => CurrentState = GameState.ContinueMenu;
    private void ExitToMain() => CurrentState = GameState.MainMenu;

    private async Task BuyHeal()
    {
        if (SaveData?.GetProperty("gold").GetInt32() >= 25)
        {
            await UpdateAndSave("gold", SaveData.Value.GetProperty("gold").GetInt32() - 25);
        }
    }

    private async Task BuyStrength()
    {
        if (SaveData?.GetProperty("gold").GetInt32() >= 150)
        {
            var bonusDmg = 0;
            try { bonusDmg = SaveData.Value.GetProperty("bonusDmg").GetInt32(); } catch {}
            await UpdateAndSave("gold", SaveData.Value.GetProperty("gold").GetInt32() - 150, "bonusDmg", bonusDmg + 5);
        }
    }

    private async Task BuyItem(string name, string slot, string model, int price)
    {
        if (SaveData?.TryGetProperty("gold", out var g) == true && g.GetInt32() >= price)
        {
            List<object> inv = new List<object>();
            if (SaveData?.TryGetProperty("inventory", out var existingInv) == true)
            {
                inv = System.Text.Json.JsonSerializer.Deserialize<List<object>>(existingInv.GetRawText()) ?? new List<object>();
            }
            inv.Add(new { name, slot, modelPath = model, id = Guid.NewGuid().ToString(), power = 1, tier = "Iron" });
            await UpdateAndSave("gold", g.GetInt32() - price, "inventory", inv);
        }
    }

    private async Task EquipItem(int index)
    {
        var invItem = GetInventoryItem(index);
        if (invItem == null) return;
        var slot = invItem.Value.GetProperty("slot").GetString();
        
        // Deserialize full lists to avoid JsonElement pointer issues
        var eq = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(SaveData.Value.GetProperty("equipment").GetRawText()) ?? new Dictionary<string, object>();
        var inv = System.Text.Json.JsonSerializer.Deserialize<List<object>>(SaveData.Value.GetProperty("inventory").GetRawText()) ?? new List<object>();
        
        // Use clean object for equipment
        var itemToEquip = inv[index];
        inv.RemoveAt(index);
        
        // If something was in slot, add back to inventory
        if (eq.ContainsKey(slot) && eq[slot] != null) inv.Add(eq[slot]);
        
        eq[slot] = itemToEquip;
        await UpdateAndSave("equipment", eq, "inventory", inv);
        
        // Live Sync: Push new gear stats to the active game engine
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.updateEquipment", eq);
        
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.initPortrait", "portraitCanvas", (object)SaveData);
    }

    private async Task UnequipItem(string slot)
    {
        var item = GetEquippedItem(slot);
        if (item == null) return;
        var eq = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(SaveData.Value.GetProperty("equipment").GetRawText());
        var inv = System.Text.Json.JsonSerializer.Deserialize<List<object>>(SaveData.Value.GetProperty("inventory").GetRawText());
        
        inv.Add(item);
        eq[slot] = null;
        await UpdateAndSave("equipment", eq, "inventory", inv);
        
        // Live Sync: Push new gear stats to the active game engine
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.updateEquipment", eq);
        
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.initPortrait", "portraitCanvas", (object)SaveData);
    }

    private async Task UpdateAndSave(params object[] kvs)
    {
        var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "dungeonSave_slot_" + activeSlot);
        var dict = System.Text.Json.JsonSerializer.Deserialize<System.Collections.Generic.Dictionary<string, object>>(saveJson) ?? new Dictionary<string, object>();
        
        for(int i=0; i<kvs.Length; i+=2) {
            dict[kvs[i].ToString()] = kvs[i+1];
        }

        var newSave = System.Text.Json.JsonSerializer.Serialize(dict);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "dungeonSave_slot_" + activeSlot, newSave);
        SaveData = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(newSave);
        StateHasChanged();
    }

    private void ResumeGame()
    {
        CurrentState = GameState.Playing;
    }

    private void ExitDungeon()
    {
        CurrentState = GameState.MainMenu;
        // Re-check for save upon exit
        CheckForSave();
    }

    private async void CheckForSave()
    {
        var saveJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "dungeonSave");
        HasSave = !string.IsNullOrEmpty(saveJson);
        StateHasChanged();
    }

    [JSInvokable]
    public void ToggleESCMenu()
    {
        if (CurrentState == GameState.Playing) CurrentState = GameState.ESCMenu;
        else if (CurrentState == GameState.ESCMenu) CurrentState = GameState.Playing;
        StateHasChanged();
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Almendra+SC&family=MedievalSharp&display=swap');

    .game-container {
        width: 100%;
        height: 100vh;
        overflow: hidden;
        margin: 0;
        padding: 0;
        background: #000;
        position: relative;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        background: rgba(0, 0, 0, 0.7);
        z-index: 100;
        color: #fff;
        text-align: center;
    }

    .main-menu {
        background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url('images/start_bg.png');
        background-size: cover;
        background-position: center;
    }

    .title-small {
        font-family: 'Almendra SC', serif;
        font-size: 3rem;
        color: #d4af37;
        margin-bottom: 2rem;
    }

    .slots-container {
        display: flex;
        gap: 20px;
        margin-bottom: 3rem;
    }

    .char-slot {
        width: 250px;
        height: 350px;
        background: rgba(20,20,25,0.9);
        border: 2px solid #555;
        padding: 20px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        transition: all 0.3s;
    }

    .char-slot.active { border-color: #d4af37; box-shadow: 0 0 15px rgba(212, 175, 55, 0.2); }
    .char-slot.active:hover { border-color: #fff; box-shadow: 0 0 25px rgba(212, 175, 55, 0.4); }

    .slot-info { margin-bottom: 2rem; }
    .slot-name { font-family: 'Almendra SC'; font-size: 1.8rem; color: #d4af37; margin-bottom: 0.5rem; }
    .slot-stats { font-family: 'MedievalSharp'; color: #aaa; margin-bottom: 0.3rem; }
    .slot-floor { font-family: 'MedievalSharp'; color: #888; }
    
    .slot-actions { display: flex; flex-direction: column; gap: 10px; width: 100%; }
    .slot-empty-text { font-family: 'MedievalSharp'; color: #444; font-size: 1.2rem; margin-bottom: 2rem; }

    .name-entry { display: flex; flex-direction: column; gap: 10px; width: 100%; }
    .name-entry input { background: #333; border: 1px solid #d4af37; color: #fff; padding: 10px; text-align: center; font-family: 'MedievalSharp'; font-size: 1rem; }

    .btn-slot {
        font-family: 'MedievalSharp', cursive;
        padding: 0.8rem;
        border: 1px solid #666;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-resume { background: #8b0000; color: #fff; border-color: #d4af37; }
    .btn-delete { background: #333; color: #888; font-size: 0.8rem; }
    .btn-new { background: #222; color: #d4af37; border-color: #d4af37; width: 100%; }
    .btn-create { background: #d4af37; color: #000; font-weight: bold; }

    .btn-slot:hover { transform: translateY(-2px); filter: brightness(1.2); }

    .subtitle {
        font-family: 'MedievalSharp', cursive;
        font-size: 1.2rem;
        color: #aaa;
        margin-top: 2rem;
        letter-spacing: 0.2rem;
    }

    .btn-start {
        font-family: 'MedievalSharp', cursive;
        padding: 1.5rem 4rem;
        font-size: 2rem;
        background: #8b0000;
        color: white;
        border: 3px solid #d4af37;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 0 15px rgba(139, 0, 0, 0.5);
    }

    .btn-start:hover {
        background: #a52a2a;
        transform: scale(1.05);
        box-shadow: 0 0 25px rgba(212, 175, 55, 0.8);
    }

    .btn-continue {
        margin-bottom: 1rem;
    }

    .btn-newgame {
        width: 200px !important;
        background: #333 !important;
        border-color: #666 !important;
    }

    .status-summary {
