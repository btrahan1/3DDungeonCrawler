@page "/"
@using _3DDungeonCrawler.Components
@using _3DDungeonCrawler.Services
@inject IJSRuntime JSRuntime
@inject GameStateService State
@implements IDisposable

<PageTitle>3D Dungeon Crawler (@State.CurrentState)</PageTitle>

<div class="game-container">
    <canvas id="renderCanvas" style="width: 100%; height: 100vh; touch-action: none;"></canvas>

    @if (State.CurrentState == GameState.MainMenu)
    {
        <div class="overlay main-menu">
            <h1 class="title">DUNGEON CRAWLER</h1>
            <button class="btn-start" @onclick="() => State.CurrentState = GameState.CharacterSelect">START JOURNEY</button>
            <div class="subtitle">Descend into the darkness...</div>
        </div>
    }

    @if (State.CurrentState == GameState.CharacterSelect)
    {
        <CharacterSelect />
    }

    @if (State.CurrentState == GameState.ContinueMenu)
    {
        <LobbyMenu OnStartDungeon="StartDungeon" />
    }

    @if (State.CurrentState == GameState.Bank)
    {
        <VaultMenu />
    }

    @if (State.CurrentState == GameState.Shop)
    {
        <MerchantMenu />
    }

    @if (State.CurrentState == GameState.CharacterSheet || State.CurrentState == GameState.ESCMenu)
    {
        <CharacterSheet />
    }

    <LootBanner />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        State.OnStateChanged += HandleStateChanged;
        await State.Initialize();
    }

    private void HandleStateChanged() => StateHasChanged();

    public void Dispose()
    {
        State.OnStateChanged -= HandleStateChanged;
    }

    private async Task StartDungeon()
    {
        State.CurrentState = GameState.Playing;
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.init", "renderCanvas", DotNetObjectReference.Create(this), State.SaveData);
    }

    private async Task InitPortrait()
    {
        await Task.Delay(150); // Give canvas time to render
        await JSRuntime.InvokeVoidAsync("window.DungeonCrawler.initPortrait", "portraitCanvas", State.SaveData);
    }

    [JSInvokable]
    public void OnPause()
    {
        State.CurrentState = GameState.ESCMenu;
        HandleStateChanged();
        _ = InitPortrait();
    }

    [JSInvokable]
    public async Task AddGold(int amount)
    {
        await State.AddGold(amount);
    }

    [JSInvokable]
    public async Task AddXP(int amount)
    {
        await State.AddXP(amount);
    }

    [JSInvokable]
    public async Task AddPotion(string type)
    {
        await State.AddPotion(type);
    }

    [JSInvokable]
    public async Task DescendFloor()
    {
        await State.DescendFloor();
    }

    [JSInvokable]
    public async Task ClaimBossLoot(int dungeonLevel)
    {
        await State.ClaimBossLoot(dungeonLevel);
    }

    [JSInvokable]
    public async Task UsePotion(string type)
    {
        await State.UsePotion(type);
    }

    [JSInvokable]
    public async Task UseAbilitySync(int mana, int stamina)
    {
        await State.UseAbilitySync(mana, stamina);
    }

    [JSInvokable]
    public void ToggleESCMenu()
    {
        if (State.CurrentState == GameState.Playing) State.CurrentState = GameState.ESCMenu;
        else if (State.CurrentState == GameState.ESCMenu) State.CurrentState = GameState.Playing;
        HandleStateChanged();
    }
}
